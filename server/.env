NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=isikconnect_db

# JWT Secret
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=30d

# Firebase (for future notifications config)
FIREBASE_SERVER_KEY=your_firebase_server_key

# Agora (for future video calls config)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
